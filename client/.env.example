# Environment Configuration for Centralized Axios Instance
# Copy this file to .env.local and update the values as needed

# API Base URL - used by the centralized Axios instance
VITE_API_BASE_URL=your site url

# Alternative URLs for different environments
# VITE_API_BASE_URL=http://localhost:5000  # Development
# VITE_API_BASE_URL=https://staging-api.shrimahalaxmimobile.in  # Staging
# VITE_API_BASE_URL=https://api.shrimahalaxmimobile.in  # Production

# Request timeout in milliseconds (optional)
VITE_API_TIMEOUT=10000

# Enable/disable request logging (optional)
VITE_ENABLE_API_LOGGING=true
